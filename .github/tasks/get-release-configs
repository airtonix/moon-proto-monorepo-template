#!/usr/bin/env bash

set -euo pipefail

cmd_help() {
  cat <<'EOF'
Usage:
  get-release-configs help
  get-release-configs print
  get-release-configs write
  get-release-configs check

Commands:
  help   Show this help
  print  Print generated packages object to stdout
  write  Update root release-please config files in-place
  check  Fail if generated packages would change tracked root configs
EOF
}

repo_root() {
  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    git rev-parse --show-toplevel
  else
    pwd
  fi
}

collect_packages() {
  local projects_json
  projects_json="$(moon query projects)"

  local pairs='[]'
  while IFS= read -r source; do
    local cfg_file="$source/.release-please-config.json"
    if [[ -f "$cfg_file" ]]; then
      if ! jq -e 'type == "object"' "$cfg_file" >/dev/null; then
        echo "Invalid JSON object: $cfg_file" >&2
        exit 1
      fi

      pairs="$(jq -cn --argjson pairs "$pairs" --arg source "$source" --slurpfile cfg "$cfg_file" '
        $pairs + [{key: $source, value: $cfg[0]}]
      ')"
    fi
  done < <(jq -r '.projects[]?.source // empty' <<<"$projects_json")

  jq -cn --argjson pairs "$pairs" '
    $pairs
    | sort_by(.key)
    | reduce .[] as $entry ({}; . + {($entry.key): $entry.value})
  '
}

render_config_with_packages() {
  local config_file="$1"
  local packages_json="$2"

  jq --argjson packages "$packages_json" '
    .packages = $packages
  ' "$config_file"
}

cmd_print() {
  collect_packages
}

cmd_write() {
  local packages_json
  packages_json="$(collect_packages)"

  local targets=(
    "release-please-config--hotfix.json"
    "release-please-config--release.json"
  )

  for target in "${targets[@]}"; do
    local tmp_file
    tmp_file="$(mktemp)"

    render_config_with_packages "$target" "$packages_json" >"$tmp_file"
    mv "$tmp_file" "$target"
  done
}

cmd_check() {
  local packages_json
  packages_json="$(collect_packages)"

  local targets=(
    "release-please-config--hotfix.json"
    "release-please-config--release.json"
  )

  local drift=0

  for target in "${targets[@]}"; do
    local tmp_file
    tmp_file="$(mktemp)"

    render_config_with_packages "$target" "$packages_json" >"$tmp_file"

    if ! cmp -s "$target" "$tmp_file"; then
      echo "Drift detected in $target" >&2
      diff -u "$target" "$tmp_file" || true
      drift=1
    fi

    rm -f "$tmp_file"
  done

  if [[ "$drift" -ne 0 ]]; then
    echo "Run .github/tasks/get-release-configs write and commit the result." >&2
    exit 1
  fi
}

main() {
  local subcmd="${1:-help}"

  cd "$(repo_root)"

  case "$subcmd" in
    help)
      cmd_help
      ;;
    print)
      cmd_print
      ;;
    write)
      cmd_write
      ;;
    check)
      cmd_check
      ;;
    *)
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
